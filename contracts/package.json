{
  "name": "@genesis-locker/contracts",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/GenesisPad/genesis-locker"
  },
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:robinhood": "hardhat run scripts/deploy.ts --network robinhood",
    "deploy:ethereum": "hardhat run scripts/deploy.ts --network ethereum",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:local-fixture": "hardhat run scripts/deploy-local-fixture.ts --network localhost",
    "deploy:local-demo": "hardhat run scripts/deploy-local-demo.ts --network localhost",
    "export:abi": "hardhat run scripts/export-abi.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.18",
    "typescript": "^5.6.3",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.7"
  }
}
